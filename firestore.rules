rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasOnlyKeys(data, keys) {
      return data.keys().hasOnly(keys);
    }

    function validImportCreate(data, uid) {
      return hasOnlyKeys(data, [
        'uid',
        'fileName',
        'fileSize',
        'rowCount',
        'source',
        'status',
        'mimeType',
        'createdAt',
        'updatedAt',
        'retentionExpiresAt',
        'extensionUsed',
        'reminderOffsetsSent',
        'encryptedOriginal'
      ])
      && data.uid == uid
      && data.fileName is string
      && data.fileSize is int
      && data.rowCount is int
      && data.source in ['csv-xlsx', 'json']
      && data.status in ['uploaded', 'processed']
      && data.createdAt is int
      && data.updatedAt is int
      && data.retentionExpiresAt is int
      && data.extensionUsed is bool
      && data.reminderOffsetsSent is list;
    }

    function validImportUpdate(newData, oldData, uid) {
      return newData.uid == uid
        && newData.createdAt == oldData.createdAt
        && newData.fileName == oldData.fileName
        && newData.fileSize == oldData.fileSize
        && newData.source == oldData.source;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;

      match /imports/{importId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && validImportCreate(request.resource.data, uid);
        allow update: if isOwner(uid) && validImportUpdate(request.resource.data, resource.data, uid);
        allow delete: if isOwner(uid);
      }

      match /notifications/{notificationId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && hasOnlyKeys(request.resource.data, ['title', 'message', 'severity', 'createdAt', 'readAt'])
          && request.resource.data.title is string
          && request.resource.data.message is string
          && request.resource.data.severity in ['info', 'success', 'warning', 'error']
          && request.resource.data.createdAt is int;
        allow update: if isOwner(uid)
          && hasOnlyKeys(request.resource.data, ['title', 'message', 'severity', 'createdAt', 'readAt'])
          && request.resource.data.title == resource.data.title
          && request.resource.data.message == resource.data.message
          && request.resource.data.severity == resource.data.severity
          && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(uid);
      }

      match /analytics/{docId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) && docId == 'overview';
      }
    }
  }
}
